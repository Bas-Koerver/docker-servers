# =============================================================================
# Paths
# =============================================================================

# Directory where application/configuration data is stored.
# Example: /opt/docker/appdata
APPDATA_LOCATION=

# Directory where Docker secret files are stored.
# Example: /opt/docker/secrets
SECRETS_LOCATION=


# =============================================================================
# Authentik secrets
# =============================================================================

# Filename of the Authentik secret key file inside SECRETS_LOCATION.
# Example: authentik_secret_key
AUTHENTIK_SECRET_KEY_FILE=


# =============================================================================
# PostgreSQL secrets
# =============================================================================

# Filename of the PostgreSQL password file inside SECRETS_LOCATION.
# Example: authentik_postgres_password
PG_PASS_FILE=