# =============================================================================
# Paths
# =============================================================================

# Directory where application and configuration data is stored.
# Example: /opt/docker/appdata
APPDATA_LOCATION=

# Directory where media files are stored.
# Example: /mnt/media
DATA_LOCATION=

# Directory where Docker secret files are stored.
# Example: /opt/docker/secrets
SECRETS_LOCATION=


# =============================================================================
# OpenID Connect
# =============================================================================

# Docker secret filename containing the OIDC client ID.
AUTOBRR_OIDC_CLIENT_ID_FILE=

# Docker secret filename containing the OIDC client secret.
AUTOBRR_OIDC_CLIENT_SECRET_FILE=

# OIDC issuer URL.
# Template: https://your-identity-provider
AUTOBRR_CONFIGURATION_ISSUER=

# OIDC callback URL configured in the identity provider.
# Template: https://your-autobrr-instance/api/auth/oidc/callback
AUTOBRR_REDIRECT_URL=