# =============================================================================
# Paths
# =============================================================================

# Directory where application/configuration data is stored.
# Example: /opt/docker/appdata
APPDATA_LOCATION=

# Directory where Docker secret files are stored.
# Example: /opt/docker/secrets
SECRETS_LOCATION=


# =============================================================================
# Traefik / Let's Encrypt
# =============================================================================

# Email address used for ACME / Let's Encrypt registration.
ACME_EMAIL=


# =============================================================================
# Error Pages
# =============================================================================

# Error page template used by tarampampam/error-pages.
# Example: cats, ghost, hacker-terminal, shuffle
TEMPLATE=cats

# Disable localization.
DISABLE_L10N=true

# Show additional error details.
SHOW_DETAILS=true


# =============================================================================
# Cloudflare DNS-01 Challenge
# =============================================================================

# File names inside SECRETS_LOCATION containing Cloudflare credentials.
# See: https://go-acme.github.io/lego/dns/cloudflare/

# Cloudflare account email file.
CLOUDFLARE_EMAIL_FILE=

# Cloudflare DNS API token file.
CLOUDFLARE_DNS_TOKEN_FILE=

# Cloudflare Zone API token file.
CLOUDFLARE_ZONE_TOKEN_FILE=